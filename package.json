{
  "name": "national-treemap",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 8000",
    "dev:fresh": "sh scripts/dev-fresh.sh",
    "server": "node server/index.mjs",
    "build": "npm run aggregate:city-tree && tsc -b && vite build",
    "deploy:worker": "wrangler deploy",
    "lint": "eslint .",
    "preview": "vite preview",
    "verify:csv": "node scripts/verify-csv.mjs",
    "convert:csv": "node scripts/convert-csv-to-utf8.mjs",
    "split:sido": "node scripts/split-by-sido.mjs",
    "parse:busan-jingu": "node scripts/parse-busan-jingu.mjs",
    "parse:busan-saha": "node scripts/parse-busan-saha.mjs",
    "parse:busan-junggu": "node scripts/parse-busan-junggu.mjs",
    "parse:busan-dongnae": "node scripts/parse-busan-dongnae.mjs",
    "parse:busan-yeongdo": "node scripts/parse-busan-yeongdo.mjs",
    "parse:busan-ugis": "node scripts/parse-busan-ugis.mjs",
    "aggregate:city-tree": "node scripts/aggregate-city-tree.mjs"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@turf/centroid": "^7.3.4",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "iconv-lite": "^0.7.2",
    "leaflet": "^1.9.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "wrangler": "^4.0.0"
  }
}
